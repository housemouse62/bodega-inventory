<html>
  <head>
    <title><%= items.title %></title>
  </head>
  <body>
    <ul>
      <% items.forEach((item) => { %>
        <h3><%= item.name %></h3>
        <a href="/items/<%= item.id %>?from=/items">View Item</a>
        <% }); %>      
    </ul>
    <footer>
      <a href="/">Home</a>
    </footer>
  </body>
</html>
