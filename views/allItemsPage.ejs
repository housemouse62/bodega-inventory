<html>
  <head>
    <title><%= items.title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="main-header">
      <div class="logo-nav-form">
        <a href="/"><img class="small-logo" src="/images/EverybodyLogo.jpeg" alt="Everybody's Bodega logo"></a>
            <div class="nav-form">
              <nav class="main-nav">
                  <a class="main-links" href="/">All Categories</a>
                  <a class="main-links" href="/items">All Items</a>
                  <%- include("../partials/loginLogout.ejs") %>
              </nav>
              <%- include("../partials/form.ejs") %>
            </div>
      </div>
    </header>
          <span class="back-to-link"><a href="/">Back to Categories</a></span>

    <main id="main-content" class="category-div">
      <table class="items-table">
            <thead>
              <tr>
                <th></th>
                <th><span class="th-inner">Name<a href="/items/?sort=name&order=ASC"><img class="sort-icon" src="/icons/sort-alph-asc.svg"></a><a href="/items/?sort=name&order=DESC"><img class="sort-icon" src="/icons/sort-alph-desc.svg"></a></span></th>
                <th><span class="th-inner">Size</span></th>
                <th><span class="th-inner">Price<a href="/items/?sort=price&order=ASC"><img class="sort-icon" src="/icons/sort-asc.svg"></a><a href="/items/?sort=price&order=DESC"><img class="sort-icon" src="/icons/sort-desc.svg"></a></span></th>
                <th><span class="th-inner">Stock<a href="/items/?sort=stock&order=ASC"><img class="sort-icon" src="/icons/sort-asc.svg"></a><a href="/items/?sort=stock&order=DESC"><img class="sort-icon" src="/icons/sort-desc.svg"></a></span></th>
              </tr>
            </thead>
            <tbody>
                <% items.forEach((item) => { %>
                  <tr class="item-row">
                    <td><a class='open-link' href="/items/<%= item.id %>?from=/items&fromName=All Items"><img class="item-image fallback" src="/images/<%= item.image_url %>" alt="<%= item.name %>"></a></td>
                    <td><div class="name-cell"><a class="item-name" href="/items/<%= item.id %>?from=/items&fromName=All Items"><%= item.name %></a><a class="edit-item-button" href="?edit=<%= item.id %>">Edit Item</a></div></td>
                    <td><%= item.size %></td>
                    <td>$<%= item.price %></td>
                    <td><%= item.stock %></td>
                  </tr>
                <% }); %> 
            </tbody>
            </table>
          </main>
        <footer>Thought Windows</footer>
    <script src="/scripts/scrollPosition.js"></script>
    <script src="/scripts/errorEvent.js"></script>
  </body>
</html>
