<html>
  <head>
    <title><%= items.category_name %></title>
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <header class="main-header">
      <div class="logo-nav-form">
        <a href="/"><img class="small-logo" src="/images/EverybodyLogo.jpeg" alt="Everybody's Bodega logo"></a>
            <div class="nav-form">
              <nav class="main-nav">
                  <a class="main-links" href="/categories">Categories</a>
                  <a class="main-links" href="/items">Items</a>
              </nav>
              <%- include("../partials/form.ejs") %>
            </div>
      </div>
    </header>
    <div class="category-div">
        <h1><%= items[0].category_name %></h1>
          <table class="items-table">
            <thead>
              <tr>
                <th></th>
                <th>Name<a href="/category/<%= items[0].category_id %>?sort=item_name">Sort Asc</a></th>
                <th>Size</th>
                <th>Price<a href="/category/<%= items[0].category_id %>?sort=item_price">Sort Asc</a></th>
                <th>Stock<a href="/category/<%= items[0].category_id %>?sort=item_stock">Sort Asc</a></th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach((item) => { %>
                <tr class="item-row">
                  <td><a class='open-link' href="<%= `/items/${item.item_id}`%>?from=/category/<%= categoryID %>&categoryName=<%= categoryName %>"><img class="item-image" src="/images/<%= item.item_url %>" alt="<%= item.item_name %>" onerror="this.src='/images/placeholder.jpeg'"></a></td>
                  <td><a class="item-name" href="<%= `/items/${item.item_id}`%>?from=/category/<%= categoryID %>&categoryName=<%= categoryName %>"><%= item.item_name %></a><a href="?edit=<%= item.item_id %>">Edit Item</a></td>
                  <td><%= item.item_size %></td>
                  <td>$<%= item.item_price %></td>
                  <td><%= item.item_stock %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
      </div>
    <footer>
          Application created by Thought Windows
    </footer>
    <script>
      window.addEventListener('load', () => {
        const scroll = sessionStorage.getItem('scrollY');
        if (scroll) {
          window.scrollTo(0, parseInt(scroll));
          sessionStorage.removeItem('scrollY');
        }
      });

      document.querySelector('form').addEventListener('submit', () => {
        sessionStorage.setItem('scrollY', window.scrollY);
      });

      document.querySelectorAll('a[href*="?edit="]').forEach(link => {
        link.addEventListener('click', () => {
          sessionStorage.setItem('scrollY', window.scrollY);
        });
      });
    </script>
  </body>
</html>
