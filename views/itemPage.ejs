<html>
  <head>
    <title><%= items.item_name %></title>
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <header class="main-header">
      <div class="logo-nav-form">
        <a href="/"><img class="small-logo" src="/images/EverybodyLogo.jpeg" alt="Everybody's Bodega logo"></a>
            <div class="nav-form">
              <nav class="main-nav">
                  <a class="main-links" href="/">All Categories</a>
                  <a class="main-links" href="/items">All Items</a>
                  <%- include("../partials/loginLogout.ejs") %>
              </nav>
              <%- include("../partials/form.ejs") %>
            </div>
      </div>
    </header>
    <div class="item-div">
      <span class="back-to-link"><a href="<%= from %>">Back to <%= fromName %></a></span>
      <div class="item-overview">
        <img class="item-image-large fallback" src="/images/<%= items[0].item_url %>" alt="<%= items[0].item_name %>">
        <div class="item-info">
          <div> 
            <h1><%= items[0].item_name %></h1>
            <% items.forEach((item) => { %>
            <h3><%= item.category_name %></h3>
            <% }); %>      
            <h4>$<%= items[0].item_price %></h4>
          </div>
          <div>      
            <h4>In Stock: <%= items[0].item_stock %></h4>
            <h5><%= items[0].item_sku %></h5>
          </div> 
          <a class="edit-item-button" href="?edit=<%= items[0].item_id %>&from=/items/<%= items[0].item_id %>&fromName=<%= fromName %>">Edit Item</a>
          <a class="delete-button" href="/items/<%= items[0].item_id %>/confirmDeleteItem?from=<%= from %>&fromName=<%= fromName %>">Delete Item</a>
        </div>
      </div>
    </div>
    <script src="/scripts/errorEvent.js"></script>
    <footer>
          Thought Windows
    </footer>
  </body>
</html>
