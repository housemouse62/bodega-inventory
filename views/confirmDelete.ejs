<html>
  <head>
    <title>Confirm Delete <%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <header class="main-header">
      <div class="logo-nav-form">
        <a href="/"
          ><img
            class="small-logo"
            src="/images/EverybodyLogo.jpeg"
            alt="Everybody's Bodega logo"
        /></a>
        <div class="nav-form">
          <nav class="main-nav">
            <a class="main-links" href="/">All Categories</a>
            <a class="main-links" href="/items">All Items</a>
                  <%- include("../partials/loginLogout.ejs") %>
          </nav>
          <%- include("../partials/form.ejs") %>
        </div>
      </div>
    </header>
    <div class="item-div">
      <span class="back-to-link"
        ><a href="<%= from %>">Back to <%= categoryName %></a></span
      >
      <div class="item-overview">
        <img class="item-image-large fallback" src="/images/<%= item[0].item_url %>" alt="<%= item[0].item_name %>">
        <div class="item-info">
          <h1>Confirm Delete Item?</h1>
          <h3><%= item[0].item_name %></h3>
          <form
            method="POST"
            action="/items/<%= item[0].item_id %>/deleteItem?from=<%= from %>&categoryName=<%= categoryName || '' %>"
          >
            <br />
            <button type="submit" class="form-button confirm">Confirm</button>
          </form>
          <%- include("../partials/passwordErrors.ejs") %>
        </div>
      </div>
    </div>
    <footer>
          Thought Windows
    </footer>
    <script src="/scripts/errorEvent.js"></script>
  </body>
</html>
